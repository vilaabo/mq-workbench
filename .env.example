# ==============================
# IBM MQ Connection Settings
# ==============================

# MQ server host / IP
MQ_HOST=localhost

# Listener port (default IBM MQ: 1414)
MQ_PORT=1414

# Server connection channel
MQ_CHANNEL=DEV.ADMIN.SVRCONN

# Queue Manager name
MQ_QMGR=QM1

# Default target queue
MQ_QUEUE=DEV.QUEUE.1

# ==============================
# Authentication (optional)
# ==============================

# Uncomment if your MQ requires username/password
# MQ_USER=app
# MQ_PASSWORD=secret
