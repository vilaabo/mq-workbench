# mq-workbench configuration.
# Copy to .env (it is gitignored) or pass the same values as CLI args / env vars.
# Priority: CLI args > environment variables > .env

# Queue manager host / IP
MQ_HOST=localhost

# Listener port (IBM MQ default: 1414)
MQ_PORT=1414

# Server connection channel
MQ_CHANNEL=DEV.APP.SVRCONN

# Queue manager name
MQ_QMGR=QM1

# Optional: user/password (setting MQ_USER enables MQCSP authentication)
# MQ_USER=app
# MQ_PASSWORD=passw0rd

# Optional: HTTP API port (default 8080)
# API_PORT=8080
